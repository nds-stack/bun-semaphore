{
  "name": "@nds-stack/bun-semaphore", "version": "0.1.0-alpha.0",
  "description": "Async semaphore for Bun — acquire/release, timeout, FIFO, zero deps",
  "author": "nds-stack <nds.stack@gmail.com>", "type": "module",
  "main": "dist/index.js", "types": "dist/index.d.ts",
  "scripts": {
    "test": "bun test", "lint": "eslint .", "typecheck": "tsc --noEmit",
    "prepublishOnly": "bun run lint && bun run typecheck && bun test && bun run build",
    "build": "bun build ./src/index.ts --outdir=./dist --target=bun --format=esm && tsc -p tsconfig.build.json"
  },
  "files": ["dist/", "README.md"],
  "repository": { "type": "git", "url": "git+https://github.com/nds-stack/bun-semaphore.git" },
  "publishConfig": { "access": "public" },
  "devDependencies": { "@eslint/js": "^10.0.1", "@types/bun": "latest", "eslint": "^10.3.0", "typescript-eslint": "^8.59.2" },
  "engines": { "bun": ">=1.3.0" }, "keywords": ["bun", "semaphore", "lock", "async"], "license": "MIT"
}
